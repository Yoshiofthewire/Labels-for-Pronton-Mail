LUMO_BASE_URL=http://127.0.0.1:3333
LUMO_LOCAL_ENABLED=true
# Put your generated Lumo auth file at /lumo_lab/config/lumo-auth.json volume path.
LUMO_AUTH_FILE=/lumo_lab/config/lumo-auth.json

# Proton token artifact written by /api/proton/auth conversion flow
PROTON_AUTH_FILE=/lumo_lab/config/proton-auth.json

# Optional overrides
PROTON_API_HOST=
TUNING_FILE=/lumo_lab/config/TUNING.md
TZ=America/New_York
